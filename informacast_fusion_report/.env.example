# Copy this file to .env and fill in your values. Never commit the real .env.

# Bearer token from Fusion Admin > Users > (your service user) > User Tokens > Add
IC_FUSION_TOKEN=paste-your-token-here

# Base URL of the Fusion API. Almost always the default below — change only if
# Singlewire support has told you your org uses a different regional endpoint.
IC_FUSION_BASE_URL=https://api.icmobile.singlewire.com/api/v1

# Optional: request timeout in seconds
IC_FUSION_TIMEOUT=30
